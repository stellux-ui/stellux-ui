{
  "name": "stellux-ui",
  "version": "0.6.0",
  "description": "Stellux UI - A Vue 3 component library with high freedom, high inclusivity, and high performance",
  "main": "dist/stellux-ui.umd.js",
  "module": "dist/stellux-ui.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/stellux-ui.es.js",
      "require": "./dist/stellux-ui.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@stellux/components": "workspace:*",
    "@stellux/directives": "workspace:*",
    "@stellux/hooks": "workspace:*",
    "@stellux/utils": "workspace:*",
    "@stellux/theme": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "ui",
    "stellux"
  ],
  "license": "MIT",
  "homepage": "https://github.com/stellux-ui/stellux-ui",
  "bugs": "https://github.com/stellux-ui/stellux-ui/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/stellux-ui/stellux-ui.git"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ]
}